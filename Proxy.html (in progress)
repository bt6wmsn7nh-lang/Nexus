<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Nexus Proxy</title>
<style>
body{
 margin:0;
 font-family:Arial;
 background:#2e2e2e;
 color:white;
 text-align:center;
}




#topbar{
 background:#1f1f1f;
 padding:10px;
}




input{
 width:60%;
 padding:10px;
 border:none;
 border-radius:5px;
}




button{
 padding:10px 15px;
 border:none;
 background:#4CAF50;
 color:white;
 border-radius:5px;
 cursor:pointer;
}




iframe{
 width:100%;
 height:90vh;
 border:none;
}
</style>
</head>




<body>




<div id="topbar">
 <input id="url" placeholder="Enter a URL (example.com)">
 <button onclick="go()">Search</button>
</div>




<iframe id="frame"></iframe>




<script>
function go(){
 let url = document.getElementById("url").value.trim();




 if(!url.startsWith("http")){
   url = "https://" + url;
 }




 // public proxy gateway
 const proxy = "https://thingproxy.freeboard.io/fetch/";




 document.getElementById("frame").src = proxy + url;
}
</script>




</body>
</html>






